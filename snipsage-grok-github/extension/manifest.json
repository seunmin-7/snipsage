{
  "manifest_version": 3,
  "name": "SnipSage",
  "version": "0.3.0",
  "description": "Snip part of a webpage and receive a compact AI response through a Grok-powered backend.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Start SnipSage",
    "default_popup": "popup.html"
  },
  "commands": {
    "start-snipping": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Start selecting a region of the current page"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "result.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
